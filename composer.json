{
    "name": "pavel-mironchik/laravel-backup-panel",
    "description": "An interface for Spatie Laravel Backup package",
    "homepage": "https://github.com/pavel-mironchik/laravel-backup-panel",
    "keywords": [
        "backup",
        "database",
        "laravel-backup",
        "spatie"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Pavel Mironchik",
            "email": "mironchikpavel@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.40|^13.0",
        "spatie/laravel-backup": "^10.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0|^11.0",
        "phpunit/phpunit": "^11.0|^12.0",
        "larastan/larastan": "^3.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "rector/rector": "^2.0",
        "laravel/pint": "^1.29"
    },
    "autoload": {
        "psr-4": {
            "PavelMironchik\\LaravelBackupPanel\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PavelMironchik\\LaravelBackupPanel\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "rector": "vendor/bin/rector process",
        "rector:test": "vendor/bin/rector process --dry-run",
        "format": "vendor/bin/pint config resources routes src tests",
        "format:test": "vendor/bin/pint config resources routes src tests --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "PavelMironchik\\LaravelBackupPanel\\LaravelBackupPanelServiceProvider"
            ]
        }
    }
}
